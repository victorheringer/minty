{
  "name": "minty",
  "version": "1.0.0",
  "description": "A lightweight, modular universal template engine built with Node.js",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "minty": "./bin/minty.js"
  },
  "scripts": {
    "minty": "node bin/minty.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "repository": "git@github.com:victorheringer/minty.git",
  "author": "Victor Heringer <victorhugo.heringer@hotmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0"
  }
}
